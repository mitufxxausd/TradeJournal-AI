VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── AI Provider Configuration ───
# Mock provider (default for development - no API key needed)
VITE_AI_MOCK_ENABLED=true
VITE_AI_MOCK_TIMEOUT=30000

# OpenAI
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o
VITE_OPENAI_ENABLED=false
VITE_OPENAI_PRIORITY=1
VITE_OPENAI_TIMEOUT=30000

# Google Gemini
VITE_GEMINI_API_KEY=
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
VITE_GEMINI_MODEL=gemini-2.0-flash
VITE_GEMINI_ENABLED=false
VITE_GEMINI_PRIORITY=2
VITE_GEMINI_TIMEOUT=30000

# Claude (Anthropic)
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_BASE_URL=https://api.anthropic.com/v1
VITE_CLAUDE_MODEL=claude-sonnet-4-20250514
VITE_CLAUDE_ENABLED=false
VITE_CLAUDE_PRIORITY=3
VITE_CLAUDE_TIMEOUT=30000

# OpenRouter
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VITE_OPENROUTER_MODEL=anthropic/claude-sonnet-4
VITE_OPENROUTER_ENABLED=false
VITE_OPENROUTER_PRIORITY=4
VITE_OPENROUTER_TIMEOUT=30000

# Groq
VITE_GROQ_API_KEY=
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1
VITE_GROQ_MODEL=llama-3.3-70b-versatile
VITE_GROQ_ENABLED=false
VITE_GROQ_PRIORITY=5
VITE_GROQ_TIMEOUT=30000

# DeepSeek
VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
VITE_DEEPSEEK_MODEL=deepseek-chat
VITE_DEEPSEEK_ENABLED=false
VITE_DEEPSEEK_PRIORITY=6
VITE_DEEPSEEK_TIMEOUT=30000

# Azure OpenAI
VITE_AZURE_OPENAI_API_KEY=
VITE_AZURE_OPENAI_BASE_URL=
VITE_AZURE_OPENAI_MODEL=gpt-4o
VITE_AZURE_OPENAI_ENABLED=false
VITE_AZURE_OPENAI_PRIORITY=7
VITE_AZURE_OPENAI_TIMEOUT=30000

# ─── Global AI Settings ───
VITE_AI_DEFAULT_TIMEOUT=30000
VITE_AI_DEFAULT_RETRIES=2
VITE_AI_ENABLE_ANALYTICS=false
VITE_AI_LOG_REQUESTS=false
VITE_AI_MAX_CONCURRENT=3
